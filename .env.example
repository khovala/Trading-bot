# Runtime mode
APP_ENV=dev
TRADING_MODE=sandbox
DRY_RUN=true
REAL_TRADING_ENABLED=false

# API
API_HOST=0.0.0.0
API_PORT=8000

# T-Invest (sandbox by default)
T_INVEST_TOKEN=
T_INVEST_ACCOUNT_ID=

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=moex-sandbox

# Monitoring
PROMETHEUS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
