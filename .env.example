APP_ENV=production
LOG_LEVEL=INFO

TRADING_MODE=sandbox
DRY_RUN=true
REAL_TRADING_ENABLED=false
PROMETHEUS_ENABLED=true

TINKOFF_TOKEN=your_tinkoff_token_here
TINKOFF_ACCOUNT_ID=your_account_id_here
TINKOFF_SANDBOX=true

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=moex-sandbox
MLFLOW_ARTIFACT_ROOT=s3://moex-trading-mlflow

YC_CLOUD_ID=your_cloud_id
YC_FOLDER_ID=your_folder_id
YC_S3_BUCKET=moex-trading-mlflow
YC_S3_ENDPOINT=https://storage.yandexcloud.net
YC_REGION=ru-central1
YC_ACCESS_KEY_ID=your_access_key
YC_SECRET_ACCESS_KEY=your_secret_key

POSTGRES_DB=trading
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=change_me_in_production

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production

ALERTMANAGER_URL=http://alertmanager:9093
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

PROMETHEUS_PORT=8001

AIRFLOW_WEBSERVER_URL=http://airflow:8080
AIRFLOW_FERNET_KEY=generate_with_python_cryptography_fernet
AIRFLOW_IMAGE=apache/airflow:2.9.3
